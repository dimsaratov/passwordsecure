<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PasswordSecure.Presentation.Controls.RevealPasswordBox"
             x:Name="Root">

  <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBox x:Name="PART_TextBox"
                 Grid.Column="0"
                 Height="30" 
                 Classes="CenteredPlaceholder"
                 PasswordChar="{Binding PasswordChar, ElementName=Root}"
                 PlaceholderText="{Binding PlaceholderText, ElementName=Root}"
                 Margin="5" />

        <Button x:Name="PART_RevealButton"
                  Grid.Column="1"
                  Content="👁"
                  Margin="5"/>
    </Grid>
</UserControl>